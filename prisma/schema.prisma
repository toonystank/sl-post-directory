// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PostOffice {
  id             String            @id @default(cuid())
  name           String
  postalCode     String
  latitude       Float?
  longitude      Float?
  operatingHours String?
  services       String[]          @default([])
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  fields         PostOfficeField[]
  users          User[]
  edits          EditRequest[]
  photos         CommunityPhoto[]

  @@index([postalCode])
  @@index([name])
}

model CommunityPhoto {
  id           String     @id @default(cuid())
  url          String
  caption      String?
  status       String     @default("APPROVED") // APPROVED by default for now
  postOfficeId String
  postOffice   PostOffice @relation(fields: [postOfficeId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@index([postOfficeId])
}

model PostOfficeField {
  id           String     @id @default(cuid())
  name         String
  type         String     // TEXT, NUMBER, BOOLEAN
  value        String
  postOfficeId String
  postOffice   PostOffice @relation(fields: [postOfficeId], references: [id], onDelete: Cascade)

  @@index([postOfficeId, name])
}

model User {
  id                String        @id @default(cuid())
  name              String
  email             String        @unique
  passwordHash      String
  role              String        @default("CONTRIBUTOR")
  emailVerified     DateTime?
  verificationToken String?       @unique
  twoFactorSecret   String?
  twoFactorEnabled  Boolean       @default(false)
  backupCodes       String[]      @default([])
  postOfficeId      String?
  postOffice        PostOffice?   @relation(fields: [postOfficeId], references: [id])
  edits             EditRequest[]
  actionLogs        ActionLog[]
}

model ActionLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String   // e.g., "APPROVED_EDIT", "REJECTED_EDIT", "CREATED_OFFICE"
  details   String   // JSON string storing target ID and context
  createdAt DateTime @default(now())

  @@index([userId])
}

model EditRequest {
  id            String     @id @default(cuid())
  postOfficeId  String?
  requestedById String
  type          String     @default("EDIT")   // EDIT, REMOVAL, ADD
  changes       String     // JSON string
  reason        String?
  status        String     @default("PENDING")
  createdAt     DateTime   @default(now())
  
  postOffice    PostOffice? @relation(fields: [postOfficeId], references: [id])
  requestedBy   User       @relation(fields: [requestedById], references: [id])
}

model SiteSettings {
  id         String   @id @default("default")
  adsEnabled Boolean  @default(true)
  updatedAt  DateTime @updatedAt
}
